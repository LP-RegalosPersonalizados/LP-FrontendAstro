---
import '../styles/globals.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CartPanel from '../components/carrito/CartPanel';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
  robots?: string;
  author?: string;
}

const {
  title,
  description = 'Recuerdos personalizados para momentos especiales en Santa Cruz de la Sierra. Tazas, álbumes, cuadros y más.',
  keywords = 'recuerdos compartidos Santa Cruz, regalos personalizados Bolivia, tazas personalizadas, álbumes fotos',
  ogImage = '/og-image.png',
  canonical,
  robots = 'index, follow',
  author = 'Recuerdos Compartidos',
} = Astro.props;

const siteUrl = Astro.site ?? 'https://www.recuerdoscompartidos.sarl';
const canonicalURL = canonical ? new URL(canonical, siteUrl) : new URL(Astro.url.pathname, siteUrl);
const fullOgImageUrl = new URL(ogImage, siteUrl);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <!-- BASIC META TAGS -->
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- GOOGLE SITE VERIFICATION -->
    <meta name="google-site-verification" content="VEAqz0lcY8TAH0941wwqQQy6RGdS1MzVqcH1n9em65Y" />

    <!-- FAVICON -->
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- SEO FUNDAMENTALS -->
    <title>{title} | Recuerdos Compartidos</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={author} />
    <meta name="robots" content={robots} />
    <meta name="language" content="Spanish" />
    <meta name="revisit-after" content="3 days" />

    <!-- GEO TAGS (Local SEO - Santa Cruz de la Sierra, Bolivia) -->
    <meta name="geo.region" content="BO-CR" />
    <meta name="geo.placename" content="Santa Cruz de la Sierra" />
    <meta name="geo.position" content="-17.7833;-63.1821" />
    <meta name="ICBM" content="-17.7833, -63.1821" />

    <!-- CANONICAL URL -->
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={canonicalURL} />

    <!-- OPEN GRAPH (SOCIAL SHARING) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImageUrl} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content="Recuerdos Compartidos" />
    <meta property="og:locale" content="es_BO" />

    <!-- TWITTER CARDS -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImageUrl} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="twitter:creator" content="@recuerdoscompartidos" />

    <!-- PERFORMANCE HINTS -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="//fonts.gstatic.com" />

    <!-- STRUCTURED DATA (JSON-LD) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://www.recuerdoscompartidos.sarl/#localbusiness",
      "name": "Recuerdos Compartidos",
      "image": "https://www.recuerdoscompartidos.sarl/og-image.png",
      "url": "https://www.recuerdoscompartidos.sarl",
      "logo": "https://www.recuerdoscompartidos.sarl/logo.png",
      "description": "Recuerdos compartidos personalizados en Santa Cruz de la Sierra, Bolivia. Tazas mágicas, álbumes de fotos, cuadros canvas y regalos únicos para momentos especiales.",
      "priceRange": "$$",
      "telephone": "+591 62699702",
      "currenciesAccepted": "BOB",
      "paymentAccepted": "Cash, Transfer",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Santa Cruz de la Sierra",
        "addressRegion": "Santa Cruz",
        "addressCountry": {
          "@type": "Country",
          "name": "Bolivia"
        }
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -17.7833,
        "longitude": -63.1821
      },
      "areaServed": {
        "@type": "City",
        "name": "Santa Cruz de la Sierra",
        "containedInPlace": {
          "@type": "Country",
          "name": "Bolivia"
        }
      },
      "sameAs": [
        "https://wa.me/59162699702"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+591 62699702",
        "contactType": "customer service",
        "areaServed": "BO",
        "availableLanguage": ["Spanish"]
      }
    }
    </script>
  </head>
  <body class="bg-white text-gray-900 font-body antialiased">
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <!-- Cart panel rendered as React island -->
    <CartPanel client:load />
  </body>
</html>
