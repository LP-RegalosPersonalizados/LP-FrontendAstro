---
import MainLayout from '../layouts/MainLayout.astro';
import BusinessIntro from '../components/empresas/BusinessIntro.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import ProductGrid from '../components/productos/ProductGrid';
import CartModeSync from '../components/carrito/CartModeSync';
import { getBusinessProducts } from '../data/products';

const businessProducts = getBusinessProducts();
---

<MainLayout
  title="Recuerdos Corporativos para Empresas"
  description="Recuerdos corporativos personalizados para empresas en Santa Cruz de la Sierra, Bolivia. Producción al por mayor con logo y diseño. Obsequios empresariales y merchandising."
  keywords="recuerdos corporativos Santa Cruz, regalos empresariales Bolivia, merchandising SCZ, obsequios empresas Santa Cruz de la Sierra"
  author="Recuerdos Compartidos"
  robots="index, follow"
  canonical="https://www.recuerdoscompartidos.sarl/empresas"
  ogImage="/og-image.png"
>
  <section class="section-padding">
    <div class="container-main">
      <BusinessIntro />

      <SectionTitle
        title="Productos para Empresas"
        subtitle="Todos disponibles en producción al por mayor con personalización"
        align="left"
      />

      <!-- Set cart to business mode when page loads -->
      <CartModeSync mode="business" client:load />

      <ProductGrid
        products={businessProducts}
        showBusinessBadge={true}
        businessMode={true}
        client:load
      />
    </div>
  </section>
</MainLayout>
