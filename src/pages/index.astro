---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/home/Hero.astro';
import FeaturedProducts from '../components/home/FeaturedProducts.astro';
import AboutUs from '../components/home/AboutUs.astro';
import WhyChooseUs from '../components/home/WhyChooseUs.astro';
import ProductCategories from '../components/home/ProductCategories.astro';
import Stats from '../components/home/Stats.astro';
import PersonalizationProcess from '../components/home/PersonalizationProcess.astro';
import WorkPreview from '../components/home/WorkPreview.astro';
import TrustBadges from '../components/home/TrustBadges.astro';
import { getFeaturedProducts } from '../data/products';

const featuredProducts = getFeaturedProducts();
---

<MainLayout
  title="Recuerdos Compartidos - Regalos Personalizados"
  description="Recuerdos compartidos personalizados en Santa Cruz de la Sierra, Bolivia. Tazas mágicas, álbumes de fotos, cuadros canvas y regalos únicos para momentos especiales."
  keywords="recuerdos compartidos sc, regalos personalizados sc, regalos personalizados, regalos bolivia, regalos santa cruz, regalos sc,recuerdos compartidos Santa Cruz, regalos personalizados Bolivia, tazas personalizadas SCZ, álbumes fotos Santa Cruz de la Sierra, cuadros canvas Bolivia"
  author="Recuerdos Compartidos"
  robots="index, follow"
  canonical="https://www.recuerdoscompartidos.sarl/"
  ogImage="/og-image.png"
>
  <!-- ============ HERO ============ -->
  <Hero products={featuredProducts} />

  <!-- ============ FEATURED PRODUCTS ============ -->
  <FeaturedProducts products={featuredProducts} />

    <!-- ============ WHY CHOOSE US ============ -->
  <WhyChooseUs />

  <!-- ============ PERSONALIZATION PROCESS ============ -->
  <PersonalizationProcess />

  <!-- ============ PRODUCT CATEGORIES ============ -->
  <ProductCategories />

  <!-- ============ STATS ============ -->
  <Stats />

  <!-- ============ WORK PREVIEW ============ -->
  <WorkPreview />

  <!-- ============ TRUST BADGES ============ -->
  <TrustBadges />

    <!-- ============ ABOUT US ============ -->
  <AboutUs />

</MainLayout>
