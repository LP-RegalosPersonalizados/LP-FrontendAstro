---
import MainLayout from '../layouts/MainLayout.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
---

<MainLayout
  title="Página no encontrada"
  description="La página que buscas no existe o ha sido movida."
  keywords="404, página no encontrada, error"
  author="Recuerdos Compartidos"
  robots="noindex, follow"
  canonical="https://www.recuerdoscompartidos.sarl/404"
>
  <section class="section-padding">
    <div class="container-main">
      <div class="max-w-2xl mx-auto text-center">
        <h1 class="font-display font-bold text-primary text-5xl mb-4">404</h1>
        <h2 class="text-3xl font-bold mb-6">Página no encontrada</h2>
        <p class="text-gray-600 text-lg mb-10">
          Lo sentimos, la página que buscas no existe o ha sido movida. Volvé a nuestra página principal o explora nuestro catálogo de regalos.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/" class="btn-primary">Ir a Inicio</a>
          <a href="/catalogo" class="btn-outline">Ver Catálogo</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
