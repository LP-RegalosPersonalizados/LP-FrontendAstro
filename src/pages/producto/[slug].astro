---
import MainLayout from '../../layouts/MainLayout.astro';
import ProductDetail from '../../components/productos/ProductDetail';
import ProductCard from '../../components/productos/ProductCard';
import { products, getProductBySlug, getRelatedProducts } from '../../data/products';
import type { GetStaticPaths } from 'astro';

/**
 * Generar solo rutas estáticas para productos que existen
 * Previene que slugs inválidos sean capturados por esta ruta dinámica
 */
export const getStaticPaths: GetStaticPaths = () => {
  return products.map((product) => ({
    params: { slug: product.slug },
  }));
};

const { slug } = Astro.params;

// En sitios estáticos, Astro solo genera las rutas definidas en getStaticPaths
// Si llegas aquí, la ruta existe y el producto debe existir
const product = getProductBySlug(slug as string);

if (!product) {
  // Si por alguna razón el producto no existe en la base de datos
  // pero la ruta fue generada, retorna 404 silenciosamente
  return new Response('Not Found', { status: 404 });
}

const related = getRelatedProducts(product, 3);
---

<MainLayout
  title={`${product.name} | Regalos Personalizados`}
  description={`${product.description} Cómpralo personalizado y hecho a tu medida. Cotiza en WhatsApp con nuestros expertos.`}
  keywords={`${product.name}, regalos personalizados, ${product.category}, regalo único`}
  author="Regalos Personalizados"
  robots="index, follow"
  canonical={`https://www.regalospersonalizados-cznl.sarl/producto/${slug}`}
  ogImage={product.image}
>
  <section class="section-padding">
    <div class="container-main">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-gray-400 mb-10" aria-label="Navegación de migas de pan">
        <a href="/" class="hover:text-primary transition-colors duration-200">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/catalogo" class="hover:text-primary transition-colors duration-200">Catálogo</a>
        <span aria-hidden="true">/</span>
        <span class="text-gray-700 font-medium" aria-current="page">{product.name}</span>
      </nav>

      <!-- Product detail -->
      <ProductDetail product={product} client:load />

      <!-- Related products -->
      {related.length > 0 && (
        <div class="mt-20">
          <h2 class="font-display font-bold text-primary text-2xl mb-8">
            También te puede gustar
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {related.map((p) => (
              <ProductCard product={p} client:visible />
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</MainLayout>
