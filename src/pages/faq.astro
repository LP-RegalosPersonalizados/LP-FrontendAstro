---
import MainLayout from '../layouts/MainLayout.astro';
import FAQPersonalizacion from '../components/faq/FAQPersonalizacion.astro';
import FAQEntregas from '../components/faq/FAQEntregas.astro';
import FAQPagos from '../components/faq/FAQPagos.astro';
import FAQGarantia from '../components/faq/FAQGarantia.astro';
import FAQEmpresas from '../components/faq/FAQEmpresas.astro';
---

<MainLayout
  title="Preguntas Frecuentes | Recuerdos Compartidos"
  description="Respuestas a tus preguntas sobre personalización, entregas, pagos, garantía y servicios corporativos. Consulta sin compromiso."
  keywords="preguntas frecuentes, FAQ, ayuda, soporte, dudas sobre regalos personalizados"
>
  <!-- Hero Section -->
  <section class="section-padding bg-gradient-to-br from-primary/10 to-accent/10">
    <div class="container-main text-center">
      <h1 class="font-display text-5xl md:text-6xl font-bold text-primary mb-4">
        Preguntas Frecuentes
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Encuentra respuestas a tus dudas más comunes sobre nuestros servicios.
      </p>
    </div>
  </section>

  <!-- Content Section with Navigation -->
  <section class="section-padding bg-white">
    <div class="container-main">
      <!-- Tabs Navigation -->
      <div class="mb-12 flex flex-wrap gap-2 justify-center">
        <a
          href="#personalizacion"
          class="px-6 py-3 rounded-full bg-primary/10 text-primary font-semibold hover:bg-primary hover:text-white transition-all duration-300 scroll-smooth"
        >
          Personalización
        </a>
        <a
          href="#entregas"
          class="px-6 py-3 rounded-full bg-gray-100 text-gray-700 font-semibold hover:bg-primary hover:text-white transition-all duration-300 scroll-smooth"
        >
          Entregas
        </a>
        <a
          href="#pagos"
          class="px-6 py-3 rounded-full bg-gray-100 text-gray-700 font-semibold hover:bg-primary hover:text-white transition-all duration-300 scroll-smooth"
        >
          Pagos
        </a>
        <a
          href="#garantia"
          class="px-6 py-3 rounded-full bg-gray-100 text-gray-700 font-semibold hover:bg-primary hover:text-white transition-all duration-300 scroll-smooth"
        >
          Garantía
        </a>
        <a
          href="#empresas"
          class="px-6 py-3 rounded-full bg-gray-100 text-gray-700 font-semibold hover:bg-primary hover:text-white transition-all duration-300 scroll-smooth"
        >
          Empresas
        </a>
      </div>

      <!-- FAQ Sections -->
      <div class="space-y-12">
        <!-- Personalización -->
        <section id="personalizacion" class="scroll-mt-20">
          <h2 class="font-display text-3xl font-bold text-primary mb-6">Personalización</h2>
          <FAQPersonalizacion />
        </section>

        <!-- Entregas -->
        <section id="entregas" class="scroll-mt-20 pt-12 border-t border-neutral-light">
          <h2 class="font-display text-3xl font-bold text-primary mb-6">Entregas</h2>
          <FAQEntregas />
        </section>

        <!-- Pagos -->
        <section id="pagos" class="scroll-mt-20 pt-12 border-t border-neutral-light">
          <h2 class="font-display text-3xl font-bold text-primary mb-6">Pagos</h2>
          <FAQPagos />
        </section>

        <!-- Garantía -->
        <section id="garantia" class="scroll-mt-20 pt-12 border-t border-neutral-light">
          <h2 class="font-display text-3xl font-bold text-primary mb-6">Garantía</h2>
          <FAQGarantia />
        </section>

        <!-- Empresas -->
        <section id="empresas" class="scroll-mt-20 pt-12 border-t border-neutral-light">
          <h2 class="font-display text-3xl font-bold text-primary mb-6">Servicios para Empresas</h2>
          <FAQEmpresas />
        </section>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section-padding bg-gradient-to-r from-accent/10 to-energy/10">
    <div class="container-main text-center">
      <h3 class="font-display text-2xl font-bold text-primary mb-3">
        ¿Tu duda no está aquí?
      </h3>
      <p class="text-gray-600 mb-6 max-w-2xl mx-auto">
        Nuestro equipo está disponible para resolver cualquier pregunta específica sobre tu proyecto.
      </p>
      <a
        href="https://wa.me/59162699702"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-8 py-3 bg-accent text-white rounded-lg font-semibold hover:bg-accent/90 transition-all duration-300"
      >
        Enviar Pregunta por WhatsApp
      </a>
    </div>
  </section>
</MainLayout>
