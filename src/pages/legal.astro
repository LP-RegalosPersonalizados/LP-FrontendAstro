---
import MainLayout from '../layouts/MainLayout.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import PoliticaPrivacidad from '../components/legal/PoliticaPrivacidad.astro';
import TerminosCondiciones from '../components/legal/TerminosCondiciones.astro';
import PoliticaEntregas from '../components/legal/PoliticaEntregas.astro';
---

<MainLayout
  title="Términos, Privacidad y Entregas | Recuerdos Compartidos"
  description="Lee nuestras políticas de privacidad, términos y condiciones, y políticas de entrega. Transparencia total en cada transacción."
  keywords="términos y condiciones, política de privacidad, política de entregas"
>
  <!-- Hero Section -->
  <section class="section-padding bg-gradient-to-br from-primary/10 to-accent/10">
    <div class="container-main text-center">
      <h1 class="font-display text-5xl md:text-6xl font-bold text-primary mb-4">
        Documentos Legales
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Nuestras políticas de privacidad, términos y condiciones, y entregas. Transparencia en todo lo que hacemos.
      </p>
    </div>
  </section>

  <!-- Content Section with Navigation -->
  <section class="section-padding bg-white">
    <div class="container-main">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Sidebar Navigation -->
        <aside class="lg:col-span-1">
          <div class="sticky top-20 bg-white rounded-lg border border-neutral-light p-6">
            <h3 class="font-display text-lg font-bold text-primary mb-4">Secciones</h3>
            <nav class="space-y-3">
              <a
                href="#privacidad"
                class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-primary/10 hover:text-primary transition-colors"
              >
                Privacidad
              </a>
              <a
                href="#terminos"
                class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-primary/10 hover:text-primary transition-colors"
              >
                Términos
              </a>
              <a
                href="#entregas"
                class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-primary/10 hover:text-primary transition-colors"
              >
                Entregas
              </a>
            </nav>
          </div>
        </aside>

        <!-- Main Content -->
        <div class="lg:col-span-3 space-y-16">
          <!-- Política de Privacidad -->
          <section id="privacidad" class="scroll-mt-20">
            <PoliticaPrivacidad />
          </section>

          <hr class="border-neutral-light" />

          <!-- Términos y Condiciones -->
          <section id="terminos" class="scroll-mt-20">
            <TerminosCondiciones />
          </section>

          <hr class="border-neutral-light" />

          <!-- Política de Entregas -->
          <section id="entregas" class="scroll-mt-20">
            <PoliticaEntregas />
          </section>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section-padding bg-gradient-to-r from-primary/10 to-accent/10">
    <div class="container-main text-center">
      <h3 class="font-display text-2xl font-bold text-primary mb-3">
        ¿Preguntas sobre nuestras políticas?
      </h3>
      <p class="text-gray-600 mb-6 max-w-2xl mx-auto">
        Contacta con nosotros sin compromiso. Responderemos cualquier duda que tengas.
      </p>
      <a
        href="https://wa.me/59162699702"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-8 py-3 bg-accent text-white rounded-lg font-semibold hover:bg-accent/90 transition-all duration-300"
      >
        Contactar Soporte
      </a>
    </div>
  </section>
</MainLayout>
