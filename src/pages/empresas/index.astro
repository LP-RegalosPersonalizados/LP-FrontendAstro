---
import MainLayout from '../../layouts/MainLayout.astro';
import BusinessIntro from '../../components/empresas/BusinessIntro.astro';
import SectionTitle from '../../components/shared/ui/SectionTitle.astro';
import ProductGrid from '../../components/shared/product/ProductGrid';
import CartModeSync from '../../components/shared/cart/CartModeSync';
import { getBusinessProducts } from '../../data/products';

const businessProducts = getBusinessProducts();
---

<MainLayout
  title="Regalos Corporativos y Empresariales Personalizados"
  description="Regalos corporativos personalizados para empresas. Producción al por mayor con logo, diseño y marca. Ideal para obsequios corporativos, eventos y merchandising."
  keywords="regalos corporativos, regalos empresariales, merchandising personalizado, regalos al mayor, obsequios para empresas, regalos con logo"
  author="Regalos Personalizados"
  robots="index, follow"
  canonical="https://www.regalospersonalizados-cznl.sarl/empresas"
  ogImage="/og-image.jpg"
>
  <section class="section-padding">
    <div class="container-main">
      <BusinessIntro />

      <SectionTitle
        title="Productos para Empresas"
        subtitle="Todos disponibles en producción al por mayor con personalización"
        align="left"
      />

      <!-- Set cart to business mode when page loads -->
      <CartModeSync mode="business" client:load />

      <ProductGrid
        products={businessProducts}
        showBusinessBadge={true}
        businessMode={true}
        client:load
      />
    </div>
  </section>
</MainLayout>
