    iconSvg: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="#f39200" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="opacity:1;"><path d="M21 7v5M3 7v10.161c0 1.383 1.946 2.205 5.837 3.848C10.4 21.67 11.182 22 12 22V11.355M15 19s.875 0 1.75 2c0 0 2.78-5 5.25-6"/><path d="M8.326 9.691L5.405 8.278C3.802 7.502 3 7.114 3 6.5s.802-1.002 2.405-1.778l2.92-1.413C10.13 2.436 11.03 2 12 2s1.871.436 3.674 1.309l2.921 1.413C20.198 5.498 21 5.886 21 6.5s-.802 1.002-2.405 1.778l-2.92 1.413C13.87 10.564 12.97 11 12 11s-1.871-.436-3.674-1.309M6 12l2 1m9-9L7 9"/></svg>',
    title: 'Entregas Flexibles',
    description: 'Retiro en nuestro punto o envío externo. Coordinamos según tu conveniencia.',
  },
];

const { benefits = defaultBenefits } = Astro.props;
---

<section class="section-padding bg-white">
  <div class="container-main">
    <div class="text-center mb-16">
      <h2 class="font-display text-4xl md:text-5xl font-bold text-primary mb-4">
        ¿Por qué elegirnos?
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        6 razones por las que somos la mejor opción para tus regalos corporativos
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {benefits.map((benefit, idx) => (
        <div class="group p-8 bg-gradient-to-br from-white to-gray-50 rounded-xl border border-neutral-light hover:border-accent hover:shadow-lg transition-all duration-300">
          <!-- Icon -->
          <div class="mb-4 transform group-hover:scale-110 transition-transform duration-300">
            {benefit.iconSvg ? (
              <div set:html={benefit.iconSvg} />
            ) : (
              <div class="text-5xl">{benefit.icon}</div>
            )}
          </div>

          <!-- Title -->
          <h3 class="font-display text-xl font-bold text-primary mb-3">
            {benefit.title}
          </h3>

          <!-- Description -->
          <p class="text-gray-600 leading-relaxed">
            {benefit.description}
          </p>

          <!-- Accent line -->
          <div class="w-0 h-1 bg-accent mt-4 group-hover:w-16 transition-all duration-300"></div>
        </div>
      ))}
    </div>
  </div>
</section>
