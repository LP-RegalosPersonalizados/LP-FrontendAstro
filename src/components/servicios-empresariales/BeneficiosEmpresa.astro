---
interface Benefit {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  benefits?: Benefit[];
}

const defaultBenefits: Benefit[] = [
  {
    icon: '🎨',
    title: 'Diseño Personalizado',
    description:
      'Cada regalo es único. Diseño 100% personalizado según tu marca y visión corporativa.',
  },
  {
    icon: '✏️',
    title: 'Revisiones Ilimitadas',
    description: 'Cambios y ajustes sin límite hasta que quedes completamente satisfecho.',
  },
  {
    icon: '⚡',
    title: 'Rápida Producción',
    description:
      'Cronogramas flexibles: desde 2-3 días para pequeños pedidos hasta 7 días para volúmenes medianos.',
  },
  {
    icon: '💰',
    title: 'Precios Competitivos',
    description: 'Descuentos significativos según cantidad. Presupuestos transparentes, sin sorpresas.',
  },
  {
    icon: '📊',
    title: 'Seguimiento Completo',
    description: 'Reportes y seguimiento en tiempo real de tu pedido desde confirmación hasta entrega.',
  },
  {
    icon: '🚚',
    title: 'Entregas Flexibles',
    description: 'Retiro en nuestro punto o envío externo. Coordinamos según tu conveniencia.',
  },
];

const { benefits = defaultBenefits } = Astro.props;
---

<section class="section-padding bg-white">
  <div class="container-main">
    <div class="text-center mb-16">
      <h2 class="font-display text-4xl md:text-5xl font-bold text-primary mb-4">
        ¿Por qué elegirnos?
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        6 razones por las que somos la mejor opción para tus regalos corporativos
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {benefits.map((benefit, idx) => (
        <div class="group p-8 bg-gradient-to-br from-white to-gray-50 rounded-xl border border-neutral-light hover:border-accent hover:shadow-lg transition-all duration-300">
          <!-- Icon -->
          <div class="text-5xl mb-4 transform group-hover:scale-110 transition-transform duration-300">
            {benefit.icon}
          </div>

          <!-- Title -->
          <h3 class="font-display text-xl font-bold text-primary mb-3">
            {benefit.title}
          </h3>

          <!-- Description -->
          <p class="text-gray-600 leading-relaxed">
            {benefit.description}
          </p>

          <!-- Accent line -->
          <div class="w-0 h-1 bg-accent mt-4 group-hover:w-16 transition-all duration-300"></div>
        </div>
      ))}
    </div>
  </div>
</section>
