---
interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  ctaText?: string;
  ctaUrl?: string;
}

const {
  title = '¿Regalos Corporativos Personalizados?',
  subtitle = 'Soluciones inteligentes para empresas',
  description = 'Impresiona a tus clientes y colaboradores con regalos corporativos únicos y personalizados. Desde pequeños detalles hasta grandes volúmenes.',
  ctaText = 'Solicitar Presupuesto',
  ctaUrl = 'https://wa.me/59162699702',
} = Astro.props;
---

<section class="relative min-h-screen flex items-center bg-gradient-to-br from-business via-primary/5 to-white overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-energy/10 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-accent/10 rounded-full blur-3xl -z-10"></div>

  <div class="container-main py-20 md:py-0">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Content -->
      <div class="space-y-6 animate-fadeInLeft">
        <div>
          <span class="inline-block px-4 py-2 bg-energy/20 text-energy-dark rounded-full text-sm font-semibold mb-3">
            Para Empresas
          </span>
          <h1 class="font-display text-5xl md:text-6xl font-bold text-primary leading-tight mb-3">
            {title}
          </h1>
          <p class="text-xl text-energy font-semibold">{subtitle}</p>
        </div>

        <p class="text-lg text-gray-600 leading-relaxed max-w-lg">
          {description}
        </p>

        <!-- Benefits list -->
        <ul class="space-y-3 my-8">
          {['Diseño 100% personalizado', 'Cambios ilimitados', 'Presupuestos sin costo'].map(
            (benefit) => (
              <li class="flex items-center gap-3">
                <span class="w-6 h-6 rounded-full bg-success flex items-center justify-center text-white text-sm font-bold">
                  ✓
                </span>
                <span class="text-gray-700 font-medium">{benefit}</span>
              </li>
            )
          )}
        </ul>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a
            href={ctaUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-accent text-white rounded-lg font-semibold hover:bg-accent/90 transition-all duration-300 text-center"
          >
            {ctaText}
          </a>
          <a
            href="#cronograma"
            class="px-8 py-4 border-2 border-primary text-primary rounded-lg font-semibold hover:bg-primary/5 transition-all duration-300 text-center"
          >
            Ver Cronograma
          </a>
        </div>
      </div>

      <!-- Right: Visual -->
      <div class="hidden lg:block relative h-full">
        <div class="relative w-full aspect-square bg-gradient-to-br from-business/20 to-accent/20 rounded-2xl flex items-center justify-center">
          <div class="text-6xl text-center space-y-4">
            <div>🎁</div>
            <div>📦</div>
            <div>✨</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mt-16 pt-12 border-t border-neutral-light">
      {[
        { value: '500+', label: 'Regalos entregados' },
        { value: '100+', label: 'Empresas satisfechas' },
        { value: '5 años', label: 'De experiencia' },
      ].map((stat) => (
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-accent font-mono">{stat.value}</p>
          <p class="text-gray-600 text-sm md:text-base">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes fadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .animate-fadeInLeft {
    animation: fadeInLeft 0.8s ease-out;
  }
</style>
