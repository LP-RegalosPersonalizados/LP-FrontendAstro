---
interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  ctaText?: string;
  ctaUrl?: string;
}

const {
  title = 'Regalos Corporativos Personalizados para tu Empresa',
  subtitle = 'Desde 10 unidades hasta 1000+. Diseño, revisiones ilimitadas, cronograma flexible y entrega garantizada.',
  description = 'Sorprende a tu equipo, clientes o socios con regalos únicos. Nuestro proceso: diseño personalizado → revisiones ilimitadas en fase de diseño → producción con control de calidad → entrega flexible.',
  ctaText = 'Solicitar Presupuesto',
  ctaUrl = 'https://wa.me/59162699702',
} = Astro.props;
---

<section class="relative py-20 md:py-15 flex items-center bg-[#DAD9D7] overflow-hidden">
  <div class="container-main w-full">
    <div class="max-w-4xl mx-auto">
      <!-- Badge -->
      <div class="inline-block px-4 py-2 bg-accent/15 text-primary rounded-full text-sm font-semibold mb-6 border border-accent/30">
        Para Empresas
      </div>

      <!-- Title -->
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-primary leading-tight mb-6">
        {title}
      </h1>

      <!-- Subtitle -->
      <p class="text-xl md:text-2xl font-semibold text-primary/80 mb-6 leading-relaxed">
        {subtitle}
      </p>

      <!-- Description -->
      <p class="text-lg text-primary/70 leading-relaxed mb-10 max-w-3xl">
        {description}
      </p>

      <!-- Benefits list -->
      <ul class="space-y-3 mb-10 max-w-2xl">
        {[
          'Revisiones de diseño ilimitadas PRE-producción',
          'Cronogramas desde 2-3 días (pequeños) a 7 días (medianos)',
          'Soporte completo del proceso',
        ].map((benefit) => (
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-accent flex items-center justify-center text-white text-sm font-bold shrink-0 mt-0.5">
              ✓
            </span>
            <span class="text-primary font-medium pt-0.5">{benefit}</span>
          </li>
        ))}
      </ul>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 pt-2">
        <a
          href={ctaUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-4 bg-accent text-white rounded-lg font-semibold hover:bg-accent/90 transition-all duration-300 text-center inline-block"
        >
          {ctaText}
        </a>
        <a
          href="#cronograma"
          class="px-8 py-4 border-2 border-primary text-primary rounded-lg font-semibold hover:bg-primary/5 transition-all duration-300 text-center inline-block"
        >
          Ver Cronograma →
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .animate-fadeInLeft {
    animation: fadeInLeft 0.8s ease-out;
  }
</style>
