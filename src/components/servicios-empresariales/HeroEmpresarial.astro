            </g>

            <text class="cls-2" transform="translate(179.43 155.63) scale(.96 1)">
              <tspan x="0" y="0">Recuerdos</tspan>
              <tspan x="0" y="46.5">Compartidos </tspan>
            </text>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>