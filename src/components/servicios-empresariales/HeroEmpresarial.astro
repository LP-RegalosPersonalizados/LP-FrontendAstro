              <path class="cls-3" d="M90.34,84.69c-.2-7.02-5.16-12.87-5.15-20.01-.09-9.79,9.9-14.58,17.11-7.59,6.95,7.52,1.75,18.37-4.62,24.24-.17.17-.46-.02-.38-.24.91-2.66,2-5.17,2.77-7.66,1.41-4.43,1.73-9.69-1.04-13.35-1.92-2.53-5.7-3.65-8.26-1.46-2.8,2.41-3.4,6.27-2.81,9.97.73,5.27,3.42,10.61,2.84,16.12-.02.27-.45.26-.45-.02h0Z"/>
            </g>

            <g>
              <path class="cls-1" d="M29.63,130.05c6.01-6.74,12.07-13.38,18.2-19.99,0,0,1.57,1.73,1.57,1.73l16.51,18.24c1.67,1.85,1.53,4.7-.32,6.38-2.08,1.93-5.55,1.38-6.94-1.09,0,0-12.41-21.19-12.41-21.19,0,0,3.15.02,3.15.02-4.22,7.02-8.39,14.09-12.47,21.17-3.55,5.54-11.42-.12-7.28-5.26h0Z"/>
              <path class="cls-1" d="M48.35,113.31c3.88,17.58,5.07,35.88,5.64,53.79.17,6.48-.01,14.2.59,20.49.3,3.02.95,5.87,1.61,7.07.34.58.47.72.81,1.01,2.18,1.35,6.18,1.48,9.05,1.71,22.48,1.16,44.7,2.96,66.96,7.18.26.02.5.26.43.54-.04.21-.23.36-.44.36l-42.89.03-21.45.02c-5.34-.09-11.23.39-16.15-2.35-7.89-4.85-7.01-17.49-7.13-25.55.53-20.76,1.11-43.66,1.16-64.31,0-.49.4-.89.89-.89.52,0,.86.41.92.89h0Z"/>
            </g>

            <g>
              <path class="cls-1" d="M163.29,186.84c-6.19,7-12.44,13.89-18.75,20.75,0,0-1.57-1.74-1.57-1.74l-17.06-18.99c-1.67-1.85-1.51-4.71.34-6.37,2.08-1.91,5.53-1.36,6.92,1.09,0,0,12.96,21.94,12.96,21.94l-3.15-.02c4.41-7.27,8.77-14.59,13.03-21.92,3.56-5.5,11.39.13,7.28,5.26h0Z"/>
