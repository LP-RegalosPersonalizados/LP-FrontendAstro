---
interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  ctaText?: string;
  ctaUrl?: string;
}

const {
  title = 'Regalos Corporativos Personalizados',
  subtitle = 'Entrega de calidad garantizada.',
  description = 'Sorprende a tu equipo, clientes o socios con regalos únicos.',
  ctaText = 'Solicitar Presupuesto',
  ctaUrl = 'https://wa.me/59162699702',
} = Astro.props;
---

<section
  class="relative min-h-[90vh] bg-primary overflow-hidden flex items-center"
  aria-label="Sección empresarial"
>
  <!-- Background decoration -->
  <div class="absolute inset-0 bg-texture opacity-30" aria-hidden="true"></div>
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-accent/20 rounded-full blur-3xl" aria-hidden="true"></div>
  <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-secondary/10 rounded-full blur-3xl" aria-hidden="true"></div>

  <div class="container-main relative z-10 py-10 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 xl:gap-16 items-center">
      <!-- Copy -->
      <div class="animate-fade-in-up">
        <span class="inline-flex items-center gap-1.5 bg-accent/20 text-accent text-sm font-medium px-4 py-1.5 rounded-full mb-6 border border-accent/30">
          <span class="w-2 h-2 bg-accent rounded-full inline-block"></span>
          Para Empresas o Venta al por Mayor
        </span>

        <h1 class="font-display font-bold text-white text-4xl md:text-5xl lg:text-5xl xl:text-6xl leading-tight mb-6">
          {title}
        </h1>

        <p class="text-white/70 text-lg md:text-xl leading-relaxed mb-6 max-w-xl">
          {subtitle}
        </p>

        <p class="text-white/60 text-base leading-relaxed mb-8 max-w-xl">
          {description}
        </p>

        <!-- Benefits list -->
        <ul class="space-y-3 mb-10 max-w-2xl">
          {[
            'Revisiones de diseño ilimitadas PRE-producción',
            'Cronogramas desde 2-3 días (pequeños) a 7 días (medianos)',
            'Soporte completo del proceso',
          ].map((benefit) => (
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-accent flex items-center justify-center text-white text-sm font-bold shrink-0 mt-0.5">
                ✓
              </span>
              <span class="text-white/80 font-medium pt-0.5">{benefit}</span>
            </li>
          ))}
        </ul>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4">
          <a
            href={ctaUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-accent text-base px-8 py-4"
            aria-label="Solicitar presupuesto empresarial"
          >
            {ctaText}
          </a>
          <a
            href="#cronograma"
            class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-medium px-8 py-4 rounded-full transition-all duration-300 text-base border border-white/20"
            aria-label="Ver cronograma de producción"
          >
            Ver Cronograma →
          </a>
        </div>
      </div>

      <!-- SVG Visual Element - OPTIMIZADO PARA MAYOR TAMAÑO -->
      <div class="hidden lg:flex items-center justify-center w-full">
        <div class="rounded-3xl overflow-hidden drop-shadow-2xl w-full transform lg:scale-110 xl:scale-100">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 563.48 272.35"
            class="w-full h-auto"
            preserveAspectRatio="xMidYMid meet"
          >
            <defs>
              <style>
                .cls-1 {
                  fill: #f39200;
                }

                .cls-2 {
                  fill: #285e50;
                  font-family: VerilySerifMono, 'Verily Serif Mono';
                  font-size: 54.25px;
                }

                .cls-3 {
                  fill: #124734;
                }
              </style>

              <!-- Fondo gradiente -->
              <linearGradient id="bgGradient" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#ffffff" />
                <stop offset="100%" stop-color="#e6e6e6" />
              </linearGradient>
            </defs>

            <!-- Fondo -->
            <rect width="563.48" height="272.35" fill="url(#bgGradient)" />

            <g>
              <path class="cls-3" d="M78.25,103.33c-10.86-3.86-21.02-9.14-29.12-17.66-6.06-6.49-9.79-16.51-6.51-25.32,3.41-9.23,14.02-14.21,22.71-8.87,5.05,2.88,8.26,7.74,11.21,12.45,5.72,9.14,10.83,19.18,11.99,30.03-1.9-10.69-7.57-20.11-13.85-28.77-4.15-5.85-9.92-12.89-17.74-11.98-4.49.64-8.31,4.5-9.54,8.77-1.97,6.92,1.51,14.25,6.58,19.02,3.52,3.38,7.91,6.04,12.52,8.35,4.6,2.28,9.42,4.09,14.34,5.38,5.88,1.78,3.32,10.36-2.59,8.6h0Z"/>
