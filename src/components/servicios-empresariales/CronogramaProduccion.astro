---
interface Timeline {
  range: string;
  days: string;
  description: string;
  color: 'accent' | 'energy' | 'information';
}

interface Props {
  items?: Timeline[];
}

const defaultItems: Timeline[] = [
  {
    range: '10-50 unidades',
    days: '2-3 días',
    description: 'Perfecta para pequeños regalos corporativos o muestras de producto.',
    color: 'energy',
  },
  {
    range: '50-100 unidades',
    days: '7 días',
    description: 'Ideal para regalos a colaboradores o clientes medianos.',
    color: 'accent',
  },
  {
    range: '100+ unidades',
    days: 'A consultar',
    description: 'Proyectos grandes con cronogramas personalizados según tu necesidad.',
    color: 'information',
  },
];

const { items = defaultItems } = Astro.props;

const colorMap = {
  accent: 'bg-accent',
  energy: 'bg-energy',
  information: 'bg-information',
};
---

<section id="cronograma" class="section-padding bg-gradient-to-br from-gray-50 to-white scroll-mt-20">
  <div class="container-main">
    <div class="text-center mb-16">
      <h2 class="font-display text-4xl md:text-5xl font-bold text-primary mb-4">
        Cronograma de Producción
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Entrega rápida según el volumen de tu pedido. Nunca más de 7 días.
      </p>
    </div>

    <!-- Timeline Desktop -->
    <div class="hidden md:block">
      <div class="relative mb-12">
        {/* Connecting line */}
        <div class="absolute top-1/2 left-0 right-0 h-1 bg-neutral-light/30 transform -translate-y-1/2 -z-10"></div>

        {/* Timeline items */}
        <div class="grid grid-cols-3 gap-6">
          {items.map((item, idx) => (
            <div class="relative">
              {/* Dot */}
              <div
                class={`absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/2 w-10 h-10 rounded-full ${
                  colorMap[item.color]
                } border-4 border-white flex items-center justify-center text-white font-bold`}
              >
                {idx + 1}
              </div>

              {/* Card */}
              <div class="pt-16 px-6 py-8 bg-white rounded-xl border border-neutral-light text-center">
                <p class="text-sm font-semibold text-gray-500 uppercase mb-2">
                  {item.range}
                </p>
                <p class={`text-3xl font-bold font-mono text-${item.color} mb-3`}>
                  {item.days}
                </p>
                <p class="text-gray-600 text-sm leading-relaxed">
                  {item.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Timeline Mobile -->
    <div class="md:hidden space-y-4">
      {items.map((item, idx) => (
        <div class="flex gap-4">
          {/* Timeline track */}
          <div class="flex flex-col items-center">
            <div
              class={`w-8 h-8 rounded-full ${colorMap[item.color]} flex items-center justify-center text-white font-bold text-sm`}
            >
              {idx + 1}
            </div>
            {idx < items.length - 1 && (
              <div class="w-1 h-12 bg-neutral-light/30 my-2"></div>
            )}
          </div>

          {/* Card */}
          <div class="py-2 px-4 bg-white rounded-lg border border-neutral-light flex-1">
            <p class="text-xs font-semibold text-gray-500 uppercase mb-1">
              {item.range}
            </p>
            <p class={`text-xl font-bold font-mono text-${item.color} mb-1`}>
              {item.days}
            </p>
            <p class="text-gray-600 text-xs leading-relaxed">
              {item.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    {/* Important note */}
    <div class="mt-12 pt-8 border-t border-neutral-light">
      <div class="bg-information/10 border-l-4 border-information p-6 rounded-lg">
        <p class="text-information font-semibold mb-2">
          ⏰ Nota importante:
        </p>
        <p class="text-gray-700">
          Los tiempos mencionados comienzan tras la confirmación y depósito del 50% del monto total. Proyectos muy complejos podrían requerir cronogramas personalizados.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .text-accent {
    color: theme('colors.accent.DEFAULT');
  }
  .text-energy {
    color: theme('colors.energy.DEFAULT');
  }
  .text-information {
    color: theme('colors.information.DEFAULT');
  }
</style>
