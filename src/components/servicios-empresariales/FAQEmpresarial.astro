---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items?: FAQItem[];
}

const defaultItems: FAQItem[] = [
  {
    question: '¿Cuál es el pedido mínimo?',
    answer: 'El pedido mínimo es de 10 unidades. Para proyectos especiales con volúmenes muy bajos, consultamos caso por caso.',
  },
  {
    question: '¿Qué tiempo tarda desde que confirmo hasta tener el producto?',
    answer: 'Depende del volumen: 10-50 unidades: 2-3 días | 50-100 unidades: 7 días | 100+ unidades: cronograma personalizado.',
  },
  {
    question: '¿Puedo hacer cambios después de confirmar el pedido?',
    answer: 'Sí, cambios menores en diseño son permitidos hasta 24 horas antes de inicio de producción. Cambios mayores podrían requerir nuevo presupuesto.',
  },
  {
    question: '¿Cómo es el proceso de pago?',
    answer: '50% de anticipo al confirmar, 50% restante antes de la entrega. Aceptamos transferencia bancaria y depósito en efectivo.',
  },
  {
    question: '¿Ofrecen envío a todo el país?',
    answer: 'Sí, realizamos envíos a todo Bolivia con transportistas confiables. El costo depende del destino y volumen. Retiro directo en Santa Cruz también disponible.',
  },
  {
    question: '¿Qué ocurre si el producto llega con defectos?',
    answer: 'Revisamos productos dentro de 24 horas de recibidos. Defectos de fabricación comprobados serán reemplazados sin costo. No aceptamos devoluciones post-entrega por otros motivos.',
  },
  {
    question: '¿Puedo ver un mockup antes de la producción?',
    answer: 'Sí, enviamos diseños en formato digital para tu aprobación. Revisiones ilimitadas hasta tu conformidad.',
  },
  {
    question: '¿Hacen productos corporativos especiales?',
    answer: 'Absolutamente. Si tienes un producto en mente que no está en catálogo, podemos personalizarlo. Consulta sin compromiso.',
  },
  {
    question: '¿Qué opciones de personalización tengo?',
    answer: 'Puedes personalizar con fotos, logos, textos, colores específicos, y más. Nuestro equipo sugiere opciones según tu producto.',
  },
  {
    question: '¿Cómo me comunico para hacer un pedido?',
    answer: 'Puedes escribirnos por WhatsApp, email, o visitarnos en persona. Nuestro equipo te asesorará desde el primer contacto.',
  },
];

const { items = defaultItems } = Astro.props;
---

<section class="section-padding bg-gradient-to-br from-gray-50 to-white">
  <div class="container-main">
    <div class="text-center mb-16">
      <h2 class="font-display text-4xl md:text-5xl font-bold text-primary mb-4">
        Preguntas Frecuentes - Empresas
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Respuestas rápidas a tus dudas más comunes sobre servicios corporativos.
      </p>
    </div>

    <div class="max-w-3xl mx-auto space-y-4">
      {items.map((item, idx) => (
        <details
          class="group p-6 bg-white rounded-lg border border-neutral-light hover:border-accent cursor-pointer transition-all duration-300"
          style={{
            animationDelay: `${idx * 0.05}s`,
          }}
        >
          <summary class="flex items-center justify-between font-semibold text-primary hover:text-accent transition-colors">
            <span class="text-lg">{item.question}</span>
            <span class="text-2xl group-open:rotate-180 transition-transform duration-300">+</span>
          </summary>
          <p class="mt-4 text-gray-600 leading-relaxed border-t border-neutral-light pt-4">
            {item.answer}
          </p>
        </details>
      ))}
    </div>

    {/* Still have questions? */}
    <div class="mt-16 pt-12 border-t border-neutral-light text-center">
      <div class="bg-gradient-to-r from-accent/10 to-energy/10 p-8 rounded-xl">
        <h3 class="font-display text-2xl font-bold text-primary mb-3">
          ¿Aún tienes dudas?
        </h3>
        <p class="text-gray-700 mb-6">
          Nuestro equipo está listo para responder cualquier pregunta específica sobre tu proyecto.
        </p>
        <a
          href="https://wa.me/59162699702"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-3 bg-accent text-white rounded-lg font-semibold hover:bg-accent/90 transition-all duration-300"
        >
          Envía tu Pregunta por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  div[style] {
    animation: slideInUp 0.6s ease-out forwards;
    opacity: 0;
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  details summary::-webkit-details-marker {
    display: none;
  }

  details[open] summary {
    color: theme('colors.accent.DEFAULT');
  }

  details[open] p {
    animation: slideInUp 0.3s ease-out;
  }
</style>
