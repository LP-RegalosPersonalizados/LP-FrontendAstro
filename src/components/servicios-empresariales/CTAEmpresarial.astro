---
interface Props {
  title?: string;
  description?: string;
  primaryCTA?: string;
  primaryURL?: string;
  secondaryCTA?: string;
  secondaryURL?: string;
}

const {
  title = '¡Hablemos de tu Proyecto!',
  description = 'No esperes más. Transforma tu experiencia de regalos corporativos con nosotros. Presupuestos sin costo, sin compromiso.',
  primaryCTA = 'Iniciar Conversación',
  primaryURL = 'https://wa.me/59162699702',
  secondaryCTA = 'Ver Catálogo Completo',
  secondaryURL = '/catalogo',
} = Astro.props;
---

<section class="relative section-padding bg-gradient-to-r from-business via-accent/20 to-energy/20 overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-10 right-10 w-72 h-72 bg-accent rounded-full mix-blend-multiply filter blur-3xl"></div>
    <div class="absolute bottom-10 left-10 w-72 h-72 bg-energy rounded-full mix-blend-multiply filter blur-3xl"></div>
  </div>

  <div class="container-main relative z-10">
    <div class="text-center space-y-8">
      {/* Main content */}
      <div class="space-y-4">
        <h2 class="font-display text-5xl md:text-6xl font-bold text-white leading-tight">
          {title}
        </h2>
        <p class="text-xl text-white/90 max-w-2xl mx-auto leading-relaxed">
          {description}
        </p>
      </div>

      {/* CTA Buttons */}
      <div class="flex flex-col sm:flex-row gap-4 justify-center pt-8">
        <a
          href={primaryURL}
          target="_blank"
          rel="noopener noreferrer"
          class="px-10 py-4 bg-white text-primary font-bold rounded-lg hover:bg-white/90 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:scale-105"
        >
          {primaryCTA}
        </a>
        <a
          href={secondaryURL}
          class="px-10 py-4 border-2 border-white text-white font-bold rounded-lg hover:bg-white/10 transition-all duration-300"
        >
          {secondaryCTA}
        </a>
      </div>

      {/* Trust indicators */}
      <div class="flex flex-wrap justify-center gap-6 pt-8 border-t border-white/20">
        {[
          { emoji: '⚡', text: 'Rápido y confiable' },
          { emoji: '💯', text: '100% personalizado' },
          { emoji: '✓', text: 'Sin sorpresas' },
        ].map((indicator) => (
          <div class="flex items-center gap-2 text-white">
            <span class="text-2xl">{indicator.emoji}</span>
            <span class="font-semibold">{indicator.text}</span>
          </div>
        ))}
      </div>
    </div>

    {/* Bottom accent line */}
    <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-white/50 to-transparent"></div>
  </div>
</section>

<style>
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.8;
    }
  }

  section {
    animation: slideInUp 0.8s ease-out;
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
