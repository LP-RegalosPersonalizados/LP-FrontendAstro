---
/**
 * Structured Data Component - JSON-LD para SEO avanzado
 * Ayuda a Google a entender mejor el contenido del sitio
 */

interface OrganizationData {
  name: string;
  url: string;
  logo: string;
  description: string;
  socials?: {
    facebook?: string;
    instagram?: string;
    whatsapp?: string;
  };
}

interface Props {
  type: 'Organization' | 'LocalBusiness' | 'Product' | 'Article';
  data: OrganizationData | any;
}

const { type, data } = Astro.props;

const siteUrl = Astro.site ?? 'https://www.recuerdoscompartidos.sarl';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': type,
  ...data,
  url: data.url || siteUrl,
};

const jsonLd = JSON.stringify(structuredData);
---

<script type="application/ld+json" set:html={jsonLd} />
