---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items?: FAQItem[];
}

const defaultItems: FAQItem[] = [
  {
    question: '¿Hay garantía en los productos?',
    answer: 'Sí, garantizamos que el producto llega en perfectas condiciones. Defectos de fabricación serán reemplazados dentro de 7 días.',
  },
  {
    question: '¿Cuándo caduca la garantía?',
    answer: 'Los reclamos por defectos deben reportarse dentro de 24 horas de recibido. Después, no aceptamos devoluciones.',
  },
  {
    question: '¿Qué se considera defecto de fabricación?',
    answer: 'Colores incorrectos, impresión borrosa, materiales rotos o dañados en fábrica, logos mal aplicados. No incluye mal uso posterior.',
  },
  {
    question: '¿Debo guardar el empaque para reclamos?',
    answer: 'No obligatoriamente, pero recomendamos guardar fotos del producto y el embalaje como evidencia.',
  },
  {
    question: '¿Puedo devolver un producto si cambié de opinión?',
    answer: 'No. Una vez entregado, no aceptamos devoluciones por cambio de parecer. Solo por defectos comprobados.',
  },
  {
    question: '¿Cómo reporto un defecto?',
    answer: 'Contacta por WhatsApp dentro de 24 horas con fotos del defecto. Nuestro equipo evaluará y procederá con el reemplazo.',
  },
];

const { items = defaultItems } = Astro.props;
---

<div class="space-y-4">
  {items.map((item, idx) => (
    <details
      class="group p-6 bg-white rounded-lg border border-neutral-light hover:border-accent cursor-pointer transition-all duration-300"
      style={{
        animationDelay: `${idx * 0.05}s`,
      }}
    >
      <summary class="flex items-center justify-between font-semibold text-primary hover:text-accent transition-colors">
        <span class="text-lg">{item.question}</span>
        <span class="text-2xl group-open:rotate-180 transition-transform duration-300">+</span>
      </summary>
      <p class="mt-4 text-gray-600 leading-relaxed border-t border-neutral-light pt-4">
        {item.answer}
      </p>
    </details>
  ))}
</div>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }

  details[open] summary {
    color: theme('colors.accent.DEFAULT');
  }

  details[open] p {
    animation: slideInUp 0.3s ease-out;
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
