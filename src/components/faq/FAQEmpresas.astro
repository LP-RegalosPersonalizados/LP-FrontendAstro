---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items?: FAQItem[];
}

const defaultItems: FAQItem[] = [
  {
    question: '¿Cuál es el pedido mínimo para empresas?',
    answer: 'El pedido mínimo es de 10 unidades. Trabajamos desde pequeños detalles corporativos hasta proyectos de 1000+ unidades. Para volúmenes especiales, consultamos caso por caso.',
  },
  {
    question: '¿Qué opciones de personalización corporativa ofrecen?',
    answer: 'Puedes personalizar con logos, nombres, colores corporativos, textos personalizados, fotos y diseños exclusivos. Nuestro equipo de diseño trabaja contigo para crear algo único que represente tu marca.',
  },
  {
    question: '¿Ofrecen descuentos por volumen?',
    answer: 'Sí, tenemos descuentos progresivos según la cantidad: 10-50 unidades (descuento base) | 50-100 unidades (10-15% descuento) | 100-300 unidades (15-25% descuento) | 300+ unidades (desde 30% descuento). Solicita cotización para volúmenes grandes.',
  },
  {
    question: '¿Cuál es el tiempo de producción según volumen?',
    answer: 'Varía según la cantidad: 10-50 unidades (2-3 días laborales) | 50-100 unidades (5-7 días) | 100-300 unidades (10-14 días) | 300+ unidades (2-4 semanas con cronograma personalizado). Los tiempos incluyen diseño, producción y control de calidad.',
  },
  {
    question: '¿Cómo es el proceso de diseño y aprobación?',
    answer: 'Primero consultamos tus necesidades. Luego enviamos diseños digitales para tu revisión. Puedes solicitar cambios ilimitados hasta tu conformidad total. Una vez aprobado, iniciamos la producción. Todo el proceso se coordina vía WhatsApp, email o reunión presencial.',
  },
  {
    question: '¿Puedo hacer cambios después de confirmar el pedido?',
    answer: 'Sí, cambios menores en diseño son permitidos hasta 24 horas antes del inicio de producción. Cambios después de ese plazo o cambios mayores podrían afectar tiempos y presupuesto. Consultamos primero para viabilidad.',
  },
  {
    question: '¿Cómo es el proceso de pago para empresas?',
    answer: '50% de anticipo al confirmar el pedido | 50% restante antes de la entrega. Aceptamos transferencia bancaria, depósito en efectivo, Paypal y otras opciones. Factura formal disponible para todos los pagos corporativos.',
  },
  {
    question: '¿Emiten factura para empresas?',
    answer: 'Sí, emitimos facturas formales para todos los pedidos corporativos. Solo necesitamos tus datos tributarios (RIF, razón social, dirección). Las facturas incluyen detalle de cantidad, descripción del producto y customizaciones realizadas.',
  },
  {
    question: '¿Ofrecen muestras antes de confirmar grandes volúmenes?',
    answer: 'Sí, podemos preparar muestras de los productos personalizados para que valides calidad y diseño. El costo de muestras puede descontarse del pedido final. Consultanos sobre disponibilidad y tiempos.',
  },
  {
    question: '¿Qué opciones de envío tienen?',
    answer: 'Realizamos envíos a todo Bolivia con transportistas confiables. Retiro directo en nuestras instalaciones en Santa Cruz también disponible. Costos de envío dependen del destino y volumen. Para grandes volúmenes, ofrecemos opciones de flete optimizado.',
  },
  {
    question: '¿Qué garantía ofrecen en productos corporativos?',
    answer: 'Revisamos productos dentro de 24 horas de recibidos. Defectos de fabricación comprobados serán reemplazados sin costo. Ofrecemos garantía de calidad en impresión, acabado y durabilidad. No aceptamos devoluciones por cambio de idea posterior a la entrega.',
  },
  {
    question: '¿Pueden personalizar productos que no están en catálogo?',
    answer: 'Absolutamente. Si tienes un producto corporativo específico en mente, podemos investigar viabilidad, costos y tiempos. Nuestro equipo propone soluciones creativas para necesidades únicas. Primera consulta sin compromiso.',
  },
  {
    question: '¿Cómo me comunico para hacer un pedido corporativo?',
    answer: 'Puedes escribirnos por WhatsApp al +591 6269-9702, enviar email, o visitarnos presencialmente en Santa Cruz. Tu asesor dedicado te guiará en todo el proceso: presupuesto, diseño, producción y entrega.',
  },
  {
    question: '¿Cuentan con experiencia en regalos de fin de año?',
    answer: 'Sí, es uno de nuestros servicios estrella. Hemos preparado campañas de fin de año para decenas de empresas. Ofrecemos desde selección de productos hasta diseño personalizado, entrega coordinada y logística completa.',
  },
];

const { items = defaultItems } = Astro.props;
---

<div class="space-y-4">
  {items.map((item, idx) => (
    <details
      class="group p-6 bg-white rounded-lg border border-neutral-light hover:border-accent cursor-pointer transition-all duration-300"
      style={{
        animationDelay: `${idx * 0.05}s`,
      }}
    >
      <summary class="flex items-center justify-between font-semibold text-primary hover:text-accent transition-colors">
        <span class="text-lg">{item.question}</span>
        <span class="text-2xl group-open:rotate-180 transition-transform duration-300">+</span>
      </summary>
      <p class="mt-4 text-gray-600 leading-relaxed border-t border-neutral-light pt-4">
        {item.answer}
      </p>
    </details>
  ))}
</div>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }

  details[open] summary {
    color: theme('colors.accent.DEFAULT');
  }

  details[open] p {
    animation: slideInUp 0.3s ease-out;
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
