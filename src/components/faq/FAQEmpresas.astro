---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items?: FAQItem[];
}

const defaultItems: FAQItem[] = [
  {
    question: '¿Hacen regalos corporativos?',
    answer: 'Claro, es nuestro especialidad. Regalos personalizados para empleados, clientes, eventos corporativos, fin de año, etc.',
  },
  {
    question: '¿Cuál es el volumen mínimo para empresa?',
    answer: 'El mínimo es 10 unidades. Manejamos desde pequeños detalles hasta proyectos de 1000+ unidades.',
  },
  {
    question: '¿Ofrecen descuentos por volumen?',
    answer: 'Sí, descuentos progresivos según cantidad. Consulta sin compromiso para una cotización personalizada.',
  },
  {
    question: '¿Puedo encargar una prueba antes de confirmar grandes volúmenes?',
    answer: 'Sí, ofrecemos muestras. Consultanos sobre costos y disponibilidad.',
  },
  {
    question: '¿Cuánto tiempo necesitan para 500+ unidades?',
    answer: 'Para volúmenes muy grandes, cronograma personalizado. Generalmente 2-4 semanas incluyendo diseño, producción y control de calidad.',
  },
  {
    question: '¿Emiten factura para empresas?',
    answer: 'Sí, emisión de factura formal para todos los pedidos corporativos. Datos tributarios necesarios.',
  },
];

const { items = defaultItems } = Astro.props;
---

<div class="space-y-4">
  {items.map((item, idx) => (
    <details
      class="group p-6 bg-white rounded-lg border border-neutral-light hover:border-accent cursor-pointer transition-all duration-300"
      style={{
        animationDelay: `${idx * 0.05}s`,
      }}
    >
      <summary class="flex items-center justify-between font-semibold text-primary hover:text-accent transition-colors">
        <span class="text-lg">{item.question}</span>
        <span class="text-2xl group-open:rotate-180 transition-transform duration-300">+</span>
      </summary>
      <p class="mt-4 text-gray-600 leading-relaxed border-t border-neutral-light pt-4">
        {item.answer}
      </p>
    </details>
  ))}
</div>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }

  details[open] summary {
    color: theme('colors.accent.DEFAULT');
  }

  details[open] p {
    animation: slideInUp 0.3s ease-out;
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
